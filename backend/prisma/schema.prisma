generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model acceso {
  acceso_id       Int               @id @default(autoincrement())
  email           String            @unique @db.VarChar(100)
  password_hash   String            @db.VarChar(255)
  rol_id          Int
  estado_usuario  Boolean?          @default(true)
  created_at      DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?         @default(now()) @db.Timestamptz(6)
  roles           roles             @relation(fields: [rol_id], references: [rol_id], onUpdate: NoAction)
  password_resets password_resets[]
  usuarios        usuarios?
}

model categorias {
  id_categoria          Int                   @id @default(autoincrement())
  nombre_categoria      String                @unique(map: "uq_categorias_nombre") @db.VarChar(80)
  descripcion_categoria String?               @db.VarChar(80)
  estado                Boolean
  productos             productos[]
  proveedor_categoria   proveedor_categoria[]
}

model clientes {
  id_cliente       Int      @id @default(autoincrement())
  nombre_cliente   String   @db.VarChar(100)
  tipo_docume      String   @db.VarChar(20)
  numero_doc       String   @unique(map: "uq_cliente_numero_doc") @db.VarChar(30)
  correo_cliente   String?  @unique(map: "uq_cliente_correo") @db.VarChar(100)
  telefono_cliente String?  @db.VarChar(20)
  estado_cliente   String   @db.VarChar(10)
  ventas           ventas[]
}

model compras {
  id_compra           Int                   @id @default(autoincrement())
  fecha_compra        DateTime              @default(now()) @db.Timestamp(6)
  id_proveedor        Int
  total               Decimal               @db.Decimal(12, 2)
  estado_compra       String?               @db.VarChar(25)
  subtotal            Decimal?              @default(0) @db.Decimal(12, 2)
  total_impuestos     Decimal?              @default(0) @db.Decimal(12, 2)
  comprobante_url     String?
  comprobante_nombre  String?
  comprobante_mime    String?
  comprobante_size    Int?
  proveedores         proveedores           @relation(fields: [id_proveedor], references: [id_proveedor], onUpdate: NoAction, map: "fk_compras_proveedor")
  detalle_compra      detalle_compra[]
  devolucion_producto devolucion_producto[]
  facturas            facturas[]
}

model detalle_compra {
  id_detalle              Int                @id @default(autoincrement())
  id_compra               Int
  cantidad                Int
  cantidad_paquetes       Int                @default(0)
  unidades_por_paquete    Int                @default(0)
  cantidad_total_unidades Int                @default(0)
  precio_unitario         Decimal            @db.Decimal(12, 2)
  subtotal                Decimal?           @db.Decimal(12, 2)
  id_detalle_producto     Int?
  iva_porcentaje          Decimal?           @db.Decimal
  icu_porcentaje          Decimal?           @db.Decimal
  precio_venta            Decimal?           @default(0) @db.Decimal(12, 2)
  compras                 compras            @relation(fields: [id_compra], references: [id_compra], onDelete: Cascade, onUpdate: NoAction, map: "fk_detalle_compra_compra")
  detalle_productos       detalle_productos? @relation(fields: [id_detalle_producto], references: [id_detalle_producto], onDelete: NoAction, onUpdate: NoAction, map: "fk_detalle_producto")
}

model detalle_devolucion_producto {
  id_detalle_devolucion_productos Int  @id @default(autoincrement())
  id_devolucion_producto          Int?
  id_detalle_producto             Int
  id_detalle_producto_creado      Int
  motivo            String?  @db.VarChar(50)
  cantidad_devuelta Int?
  es_descuento      Boolean?
  nombre_producto   String?  @db.VarChar(50)
  estado            Boolean? @default(true)
  detalle_productos   detalle_productos?   @relation(fields: [id_detalle_producto], references: [id_detalle_producto], onDelete: NoAction, onUpdate: NoAction, map: "fk_detalle_producto")
  devolucion_producto devolucion_producto? @relation(fields: [id_devolucion_producto], references: [id_devolucion_product], onDelete: NoAction, onUpdate: NoAction, map: "fk_devolucion_producto")
  detalle_producto_creado detalle_productos? @relation("detalle_creado_por_devolucion", fields: [id_detalle_producto_creado], references: [id_detalle_producto], onDelete: NoAction, onUpdate: NoAction)
}

model detalle_productos {
  id_detalle_producto           Int                            @id @default(autoincrement())
  id_producto                   Int
  codigo_barras_producto_compra String                         @db.VarChar(50)
  fecha_vencimiento             DateTime?                      @db.Date
  stock_producto                Int
  es_devolucion                 Boolean?                       @default(false)
  estado                        Boolean?
  lote                          String?                        @db.VarChar(50)
  detalle_compra                detalle_compra[]
  detalle_devolucion_producto   detalle_devolucion_producto[]
  productos                     productos                      @relation(fields: [id_producto], references: [id_producto], onDelete: Cascade, onUpdate: NoAction)
  detalle_productos_baja        detalle_productos_baja[]
  detalle_venta                 detalle_venta[]
  devolucion_cliente_entregado  devolucion_cliente_entregado[]
  facturas                      facturas[]
  conversionesOrigen            detalle_conversion_productos[] @relation("detalle_origen_conversion")
  conversionesDestino           detalle_conversion_productos[] @relation("detalle_destino_conversion")
  devoluciones_creacion         detalle_devolucion_producto[]  @relation("detalle_creado_por_devolucion")
}

model detalle_venta {
  id_detalle                  Int                           @id @default(autoincrement())
  id_venta                    Int
  cantidad                    Int
  precio_unitario             Decimal                       @db.Decimal(10, 2)
  subtotal                    Decimal?                      @db.Decimal(10, 2)
  id_detalle_producto         Int?
  iva_venta                   Decimal?                      @db.Decimal
  icu_venta                   Decimal?                      @db.Decimal
  detalle_productos           detalle_productos?            @relation(fields: [id_detalle_producto], references: [id_detalle_producto], onDelete: NoAction, onUpdate: NoAction, map: "fk_detalle_venta")
  ventas                      ventas                        @relation(fields: [id_venta], references: [id_venta], onDelete: Cascade, onUpdate: NoAction, map: "fk_detalle_venta_venta")
  devolucion_cliente_devuelto devolucion_cliente_devuelto[]
}

model devolucion_cliente {
  id_devoluciones_cliente      Int                            @id @default(autoincrement())
  id_venta                     Int?
  id_responsable               Int?
  fecha_devolucion             DateTime?                      @db.Date
  cantidad_devuelta_a_cliente  Int?
  cantidad_devuelta_cliente    Int?
  total_devolucion_cliente     Decimal?                       @db.Decimal
  total_devolucion_producto    Decimal?                       @db.Decimal
  estado                       Boolean?                       @default(true)
  usuarios                     usuarios?                      @relation(fields: [id_responsable], references: [usuario_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_responsable")
  ventas                       ventas?                        @relation(fields: [id_venta], references: [id_venta], onDelete: NoAction, onUpdate: NoAction, map: "fk_venta")
  devolucion_cliente_devuelto  devolucion_cliente_devuelto[]
  devolucion_cliente_entregado devolucion_cliente_entregado[]
  productosBajas               productos_baja[]
}

model devolucion_producto {
  id_devolucion_product       Int                           @id @default(autoincrement())
  id_responsable              Int?
  fecha_devolucion            DateTime?                     @db.Date
  cantidad_total              Int?
  nombre_responsable          String?                       @db.VarChar(20)
  numero_factura              String?                       @db.VarChar(20)
  id_compras                  Int?
  estado                      Boolean?                      @default(true)
  tipo_devolucion             String   @default("reemplazo") @db.VarChar(20)
  detalle_devolucion_producto detalle_devolucion_producto[]
  compras                     compras?                      @relation(fields: [id_compras], references: [id_compra], onDelete: NoAction, onUpdate: NoAction, map: "fk_compra")
  usuarios                    usuarios?                     @relation(fields: [id_responsable], references: [usuario_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_responsable")
  productos                   productos[]
}

model impuestos_productos {
  id_impuesto                                                    Int         @id @default(autoincrement())
  nombre_impuesto                                                String      @db.VarChar(30)
  valor_impuesto                                                 Float
  productos_productos_icuToimpuestos_productos                   productos[] @relation("productos_icuToimpuestos_productos")
  productos_productos_ivaToimpuestos_productos                   productos[] @relation("productos_ivaToimpuestos_productos")
  productos_productos_porcentaje_incrementoToimpuestos_productos productos[] @relation("productos_porcentaje_incrementoToimpuestos_productos")
}

model password_resets {
  id         Int      @id @default(autoincrement())
  acceso_id  Int
  token      String   @unique @db.VarChar(255)
  expires_at DateTime @db.Timestamptz(6)
  acceso     acceso   @relation(fields: [acceso_id], references: [acceso_id], onDelete: Cascade, onUpdate: NoAction)
}

model permisos {
  permiso_id     Int            @id @default(autoincrement())
  modulo         String         @db.VarChar(50)
  permiso_nombre String         @unique @db.VarChar(100)
  rol_permisos   rol_permisos[]
}

model producto_proveedor {
  id_producto_proveedor     Int         @id @default(autoincrement())
  id_proveedor              Int
  id_producto               Int
  estado_producto_proveedor Boolean
  productos                 productos   @relation(fields: [id_producto], references: [id_producto], onDelete: Cascade, onUpdate: NoAction)
  proveedores               proveedores @relation(fields: [id_proveedor], references: [id_proveedor], onDelete: NoAction, onUpdate: NoAction)
}

model productos {
  id_producto                                                              Int                    @id @default(autoincrement())
  nombre                                                                   String                 @db.VarChar(100)
  descripcion                                                              String?                @db.VarChar(100)
  stock_actual                                                             Int
  stock_minimo                                                             Int
  stock_maximo                                                             Int
  estado                                                                   Boolean
  id_categoria                                                             Int
  iva                                                                      Int?
  icu                                                                      Int?
  porcentaje_incremento                                                    Int?
  costo_unitario                                                           Int
  precio_venta                                                             Int
  url_imagen                                                               String?                @db.VarChar(255)
  created_at                                                               DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at                                                               DateTime?              @default(now()) @db.Timestamptz(6)
  cantidad_unitaria                                                        Int?
  desde_dev_productos                                                      Int?
  desde_baja_productos                                                     Int?
  detalle_productos                                                        detalle_productos[]
  producto_proveedor                                                       producto_proveedor[]
  productos_baja                                                           productos_baja?        @relation(fields: [desde_baja_productos], references: [id_baja_productos], onDelete: NoAction, onUpdate: NoAction)
  devolucion_producto                                                      devolucion_producto?   @relation(fields: [desde_dev_productos], references: [id_devolucion_product], onDelete: NoAction, onUpdate: NoAction)
  impuestos_productos_productos_icuToimpuestos_productos                   impuestos_productos?   @relation("productos_icuToimpuestos_productos", fields: [icu], references: [id_impuesto], onDelete: NoAction, onUpdate: NoAction)
  categorias                                                               categorias             @relation(fields: [id_categoria], references: [id_categoria], onDelete: NoAction, onUpdate: NoAction)
  impuestos_productos_productos_ivaToimpuestos_productos                   impuestos_productos?   @relation("productos_ivaToimpuestos_productos", fields: [iva], references: [id_impuesto], onDelete: NoAction, onUpdate: NoAction)
  impuestos_productos_productos_porcentaje_incrementoToimpuestos_productos impuestos_productos?   @relation("productos_porcentaje_incrementoToimpuestos_productos", fields: [porcentaje_incremento], references: [id_impuesto], onDelete: NoAction, onUpdate: NoAction)
  conversionProductos                                                      conversion_productos[] @relation("producto_creado_por_conversion")
  conversionProductosOrigen                                                conversion_productos[]
}

model productos_baja {
  id_baja_productos      Int                      @id @default(autoincrement())
  id_responsable         Int?
  fecha_baja             DateTime?                @db.Date
  cantida_baja           Int?
  total_precio_baja      Decimal?                 @db.Decimal
  nombre_responsable     String?                  @db.VarChar(50)
  estado                 Boolean?                 @default(true)
  desde_dev_cliente      Int?
  detalle_productos_baja detalle_productos_baja[]
  productos              productos[]
  usuarios               usuarios?                @relation(fields: [id_responsable], references: [usuario_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_responsable")
  devolucion_cliente     devolucion_cliente?      @relation(fields: [desde_dev_cliente], references: [id_devoluciones_cliente], onDelete: NoAction, onUpdate: NoAction)
  conversionProductos    conversion_productos[]
}

model proveedores {
  id_proveedor        Int                   @id @default(autoincrement())
  nombre              String                @db.VarChar(100)
  telefono            String?               @db.VarChar(15)
  direccion           String?               @db.VarChar(250)
  estado              Boolean               @default(true)
  descripcion         String?               @db.VarChar(225)
  nit                 String?               @unique(map: "uq_proveedores_nit")
  tipo_persona        String?               @db.VarChar(50)
  contacto            String?               @db.VarChar(100)
  correo              String?               @unique @db.VarChar(120)
  compras             compras[]
  producto_proveedor  producto_proveedor[]
  proveedor_categoria proveedor_categoria[]
}

model rol_permisos {
  rol_id     Int
  permiso_id Int
  permisos   permisos @relation(fields: [permiso_id], references: [permiso_id], onDelete: Cascade, onUpdate: NoAction)
  roles      roles    @relation(fields: [rol_id], references: [rol_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([rol_id, permiso_id])
}

model roles {
  rol_id       Int            @id @default(autoincrement())
  rol_nombre   String         @unique @db.VarChar(50)
  descripcion  String?        @db.VarChar(255)
  estado_rol   Boolean?       @default(true)
  acceso       acceso[]
  rol_permisos rol_permisos[]
}

model usuarios {
  usuario_id          Int                    @id @default(autoincrement())
  acceso_id           Int                    @unique
  nombre              String                 @db.VarChar(50)
  apellido            String?                @db.VarChar(50)
  telefono            String?                @db.VarChar(20)
  documento           String?                @unique @db.VarChar(50)
  devolucion_cliente  devolucion_cliente[]
  devolucion_producto devolucion_producto[]
  productos_baja      productos_baja[]
  acceso              acceso                 @relation(fields: [acceso_id], references: [acceso_id], onDelete: Cascade, onUpdate: NoAction)
  conversionProductos conversion_productos[]
}

model ventas {
  id_venta            Int                  @id @default(autoincrement())
  fecha_venta         DateTime             @default(now()) @db.Timestamp(6)
  id_cliente          Int?
  metodo_pago         String               @db.VarChar(20)
  total               Decimal              @db.Decimal(10, 2)
  estado_venta        String?              @default("Completada") @db.VarChar(20)
  monto_efectivo      Decimal              @default(0) @db.Decimal(10, 2)
  monto_transferencia Decimal              @default(0) @db.Decimal(10, 2)
  detalle_venta       detalle_venta[]
  devolucion_cliente  devolucion_cliente[]
  clientes            clientes?            @relation(fields: [id_cliente], references: [id_cliente], onUpdate: NoAction, map: "fk_ventas_clientes")
}

model detalle_productos_baja {
  id_detalle_productos_baja Int                @id @default(autoincrement())
  id_baja_productos         Int?
  id_detalle_productos      Int?
  cantidad                  Int?
  motivo                    String?            @db.VarChar(50)
  total_producto_baja       Decimal?           @db.Decimal(10, 2)
  nombre_producto           String?            @db.VarChar(50)
  estado                    Boolean?           @default(true)
  productos_baja            productos_baja?    @relation(fields: [id_baja_productos], references: [id_baja_productos], onDelete: NoAction, onUpdate: NoAction)
  detalle_productos         detalle_productos? @relation(fields: [id_detalle_productos], references: [id_detalle_producto], onDelete: NoAction, onUpdate: NoAction)
}

model proveedor_categoria {
  id_proveedor_categoria Int         @id @default(autoincrement())
  id_proveedor           Int
  id_categoria           Int
  created_at             DateTime?   @default(now()) @db.Timestamp(6)
  updated_at             DateTime?   @default(now()) @db.Timestamp(6)
  categorias             categorias  @relation(fields: [id_categoria], references: [id_categoria], onDelete: Cascade, map: "fk_proveedor_categoria_categoria")
  proveedores            proveedores @relation(fields: [id_proveedor], references: [id_proveedor], onDelete: Cascade, map: "fk_proveedor_categoria_proveedor")

  @@unique([id_proveedor, id_categoria], map: "uq_proveedor_categoria")
}

model devolucion_cliente_devuelto {
  id_devolucion_cliente_devuelto Int                 @id @default(autoincrement())
  id_devolucion_cliente          Int?
  id_detalle_venta               Int?
  cantidad_cliente_devuelto      Int?
  valor_unitario                 Decimal?            @db.Decimal
  condicion_producto             String?             @db.VarChar(10)
  motivo                         String?             @db.VarChar(30)
  estado                         Boolean?            @default(true)
  detalle_venta                  detalle_venta?      @relation(fields: [id_detalle_venta], references: [id_detalle], onDelete: NoAction, onUpdate: NoAction, map: "fk_detalle_venta")
  devolucion_cliente             devolucion_cliente? @relation(fields: [id_devolucion_cliente], references: [id_devoluciones_cliente], onDelete: NoAction, onUpdate: NoAction, map: "fk_devolucion_cliente")
}

model devolucion_cliente_entregado {
  id_devolucion_cliente_entregado Int                 @id @default(autoincrement())
  id_devolucion_cliente           Int?
  id_detalle_producto             Int?
  cantidad_entregada              Int?
  valor_unitario                  Decimal?            @db.Decimal
  estado                          Boolean?            @default(true)
  detalle_productos               detalle_productos?  @relation(fields: [id_detalle_producto], references: [id_detalle_producto], onDelete: NoAction, onUpdate: NoAction, map: "fk_detalle_producto")
  devolucion_cliente              devolucion_cliente? @relation(fields: [id_devolucion_cliente], references: [id_devoluciones_cliente], onDelete: NoAction, onUpdate: NoAction, map: "fk_devolucion_cliente")
}

model facturas {
  id_factura          Int               @id @default(autoincrement())
  num_factura         String            @unique @db.VarChar(50)
  comprobante_pago    String?           @db.VarChar(255)
  fecha_registro      DateTime          @default(now()) @db.Timestamp(6)
  valor_factura       Decimal           @db.Decimal(12, 2)
  iva                 Decimal           @default(0) @db.Decimal(12, 2)
  icu                 Decimal           @default(0) @db.Decimal(12, 2)
  id_compra           Int
  id_detalle_producto Int
  compras             compras           @relation(fields: [id_compra], references: [id_compra], map: "fk_factura_compra")
  detalle_productos   detalle_productos @relation(fields: [id_detalle_producto], references: [id_detalle_producto], map: "fk_factura_detalle_producto")

  @@index([id_compra], map: "idx_facturas_id_compra")
  @@index([id_detalle_producto], map: "idx_facturas_id_detalle_producto")
}

model conversion_productos {
  id_conversion_productos Int      @id @default(autoincrement())
  fecha_conversion        DateTime @default(now()) @db.Timestamp(6)
  id_responsable          Int?
  nombre_responsable      String?  @db.VarChar(50)
  estado                  Boolean  @default(true) // para anular
  observacion             String?  @db.VarChar(150)

  // Si esta conversión se hizo desde una baja (tu formulario actual)
  id_baja_productos Int?
  productos_baja    productos_baja? @relation(fields: [id_baja_productos], references: [id_baja_productos], onDelete: SetNull, onUpdate: NoAction)

  // Si en esta conversión se CREÓ el producto destino (SKU nuevo)
  id_producto_creado Int?
  producto_creado    productos? @relation("producto_creado_por_conversion", fields: [id_producto_creado], references: [id_producto], onDelete: SetNull, onUpdate: NoAction)

  usuarios usuarios? @relation(fields: [id_responsable], references: [usuario_id], onDelete: NoAction, onUpdate: NoAction)

  detalle_conversion   detalle_conversion_productos[]
  productos            productos?                     @relation(fields: [productosId_producto], references: [id_producto])
  productosId_producto Int?
}

model detalle_conversion_productos {
  id_detalle_conversion Int @id @default(autoincrement())

  id_conversion_productos Int
  conversion              conversion_productos @relation(fields: [id_conversion_productos], references: [id_conversion_productos], onDelete: Cascade, onUpdate: NoAction)

  // De cuál detalle_productos sale stock (ej: caja)
  id_detalle_origen Int
  detalle_origen    detalle_productos @relation("detalle_origen_conversion", fields: [id_detalle_origen], references: [id_detalle_producto], onDelete: NoAction, onUpdate: NoAction)

  // A cuál detalle_productos entra stock (ej: unidad)
  id_detalle_destino Int
  detalle_destino    detalle_productos @relation("detalle_destino_conversion", fields: [id_detalle_destino], references: [id_detalle_producto], onDelete: NoAction, onUpdate: NoAction)

  cantidad_origen   Int
  cantidad_destino  Int
  factor_conversion Int // ej: 1 caja = 20 unidades

  estado Boolean @default(true)
}
